# ── Market type ────────────────────────────────────────────────────────────────
# "crypto" → uses BitGet or Binance
# "forex"  → uses OANDA (set SYMBOL to e.g. EUR_USD, GBP_USD, XAU_USD)
MARKET_TYPE=crypto

# ── Crypto exchange (used when MARKET_TYPE=crypto) ─────────────────────────────
# "bitget" or "binance"
EXCHANGE=bitget

# BitGet credentials
BITGET_API_KEY=your_bitget_api_key
BITGET_SECRET_KEY=your_bitget_secret_key
BITGET_PASSPHRASE=your_bitget_passphrase
BITGET_BASE_URL=https://api.bitget.com

# Binance credentials (used when EXCHANGE=binance)
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key

# ── Forex credentials (used when MARKET_TYPE=forex) ────────────────────────────
# Get these from: OANDA → Manage API Access
# Practice account: https://www.oanda.com/register/#/sign-up/demo
OANDA_API_KEY=your_oanda_api_key
OANDA_ACCOUNT_ID=your_oanda_account_id
OANDA_PRACTICE=true

# ── Trading mode (crypto only): "spot" or "futures" ────────────────────────────
TRADE_MODE=spot

# ── Portfolio and limits ────────────────────────────────────────────────────────
PORTFOLIO_VALUE_USD=1000
MAX_TRADE_SIZE_USD=50
MAX_TRADES_PER_DAY=3

# ── Symbol and timeframe ────────────────────────────────────────────────────────
# Crypto examples : BTCUSDT, ETHUSDT
# Forex examples  : EUR_USD, GBP_USD, XAU_USD (Gold), GBP_JPY
SYMBOL=BTCUSDT
TIMEFRAME=4H

# ── Paper trading ───────────────────────────────────────────────────────────────
# true = log decisions only, no real orders placed
PAPER_TRADING=true
